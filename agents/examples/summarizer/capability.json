{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "capability": "summarize",
  "description": "Produces a short extractive summary from a list of documents.",
  "input_schema": {
    "type": "object",
    "required": ["documents"],
    "properties": {
      "documents": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "string" },
        "description": "Document bodies to summarize."
      }
    },
    "additionalProperties": false
  },
  "output_schema": {
    "type": "object",
    "required": ["summary", "document_count"],
    "properties": {
      "summary": {
        "type": "string",
        "description": "The extractive summary, truncated to 280 characters."
      },
      "document_count": {
        "type": "integer",
        "minimum": 1,
        "description": "Number of documents summarized."
      }
    },
    "additionalProperties": false
  }
}
