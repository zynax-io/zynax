use (
	./agents/adapters/adk
	./agents/adapters/ci
	./agents/adapters/git
	./agents/adapters/http
	./agents/adapters/llm
	./libs/zynaxconfig
	./libs/zynaxobs
	./protos/generated/go
	./services/agent-registry
	./services/api-gateway
	./services/engine-adapter
	./services/event-bus
	./services/memory-service
	./services/task-broker
	./services/workflow-compiler
)
